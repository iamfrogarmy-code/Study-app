import time


# --- OFFLINE TEXT TO SPEECH HELPER ---
def say_and_print(text):
    # Print it to the screen first
    print(text)

    # Strip emojis and clean math symbols for clear audio pronunciation
    clean_text = text.replace("🔴", "").replace("▭", "")
    clean_text = clean_text.replace("²", " squared ").replace("√", " square root of ")
    clean_text = clean_text.replace("*", " times ").replace("/", " divided by ")

    # Check the user's OS and trigger built-in offline engine
    if sys.platform == "darwin":  # macOS built-in speech
        os.system(f"say '{clean_text}'")
    elif sys.platform == "win32":  # Windows built-in PowerShell speech
        safe_text = clean_text.replace("'", "`'")
        os.system(
            f"powershell -Command \"Add-Type -AssemblyName System.Speech; (New-Object System.Speech.Synthesis.SpeechSynthesizer).Speak('{safe_text}')\"")
    else:
        time.sleep(0.5)


